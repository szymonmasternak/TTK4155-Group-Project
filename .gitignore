# Ignore build directories and files
build/
*.o
*.obj
*.elf
*.hex
*.bin
*.map
*.out
*.d

# Ignore dependency files generated by compilers
*.dSYM/
*.dwo
*.su
*.swp

# Ignore temporary files
*.tmp
*.temp
*.bak
*.old
*.swp
*.swo
*.swn
*.orig
*.rej
*.log

# Ignore editor and IDE specific files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Ignore system files
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# Ignore Python cache files if Python scripts are used
__pycache__/
*.py[cod]

# Ignore macOS system files
*.DS_Store

# Ignore Windows system files
Thumbs.db
ehthumbs.db

# Ignore Linux trash files
.Trash-*

# Ignore Git merge conflict files
*.orig

# Ignore files generated by Git during merge conflicts
*.orig
*.rej

# Ignore archives and compressed files
*.zip
*.tar.gz
*.tar.bz2
*.7z
*.rar

# Ignore application specific files
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore binary files generated by certain tools
*.exe
*.dll
*.so

# Ignore firmware specific files
node1/build/
firmware.bin
firmware.hex

# Ignore build artifacts from AVR toolchain
*.eeprom
*.lss
*.map
*.sym

# Ignore logs and temporary build files
*.log
*.cache
*.tmp
*.temp

# Ignore upload artifacts
artifact.zip
Node_1_Firmware.zip

# Ignore files related to package management
package-lock.json
yarn.lock
